# =============================================================================
# Gomo6 — Configuration Template
# =============================================================================
# Скопируйте в .env и заполните своими значениями.
# Либо используйте deploy.sh для автоматической генерации.
# =============================================================================

# ── Domain ──────────────────────────────────────────────────────────────────
# Для продакшна: ваш домен (e.g. example.com)
# Для разработки: localhost
DOMAIN=localhost

# ── Security ────────────────────────────────────────────────────────────────
# Сгенерируйте случайные 64-символьные hex-ключи:
#   openssl rand -hex 32
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
FEDERATION_KEY=change-me-generate-with-openssl-rand-hex-16

# ── Let's Encrypt ───────────────────────────────────────────────────────────
# Email для получения HTTPS-сертификатов (только для продакшна).
# Оставьте пустым для localhost-режима.
ACME_EMAIL=

# ── Environment ─────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ── Allowed CORS origins ────────────────────────────────────────────────────
# Для продакшна: https://example.com,http://example.com,https://docs.example.com,...
ALLOWED_ORIGINS=http://localhost,http://docs.localhost,http://dev.localhost

# ── Database (PostgreSQL) ───────────────────────────────────────────────────
# Пароль задаётся в docker-compose.yml по умолчанию:
#   POSTGRES_PASSWORD=gomo6password
# При необходимости переопределите здесь.

# ── S3 / Garage ─────────────────────────────────────────────────────────────
# Ключи для Garage S3 заданы в docker-compose.yml.
# При необходимости переопределите здесь:
# GARAGE_S3_ACCESS_KEY=GK...
# GARAGE_S3_SECRET_KEY=...
GARAGE_S3_PUBLIC_ENDPOINT=http://localhost:3900
