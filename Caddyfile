# =============================================================================
# Gomo6 — Caddy Reverse Proxy Configuration
# =============================================================================
# Set DOMAIN env var (e.g., example.com) for production with auto HTTPS.
# Without DOMAIN, defaults to localhost (HTTP only).
#
# Subdomains (automatically derived from $DOMAIN):
#   docs.{$DOMAIN}  → Documentation site
#   dev.{$DOMAIN}   → Dev Dashboard (OAuth app management)
#
# Local development with `.localhost` TLD works out of the box:
#   localhost       → Main site
#   docs.localhost  → Documentation
#   dev.localhost   → Dev Dashboard
# =============================================================================

# ── Disable auto HTTPS for local development (no -k flag needed for curl) ─
#     Remove this block for production deployment with a real domain.
{
	auto_https off
}

# ── Main Web App ────────────────────────────────────────────────────────────
{$DOMAIN:localhost} {
	# ── Security headers (applied to ALL responses) ────────────────────────
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Access-Control-Allow-Origin "{http://dev.{$DOMAIN:localhost},http://docs.{$DOMAIN:localhost}}"
	}

	# ── Logging ────────────────────────────────────────────────────────────
	log {
		output stdout
		format json
	}

	# ── Backend API (WebSocket auto-upgraded by Caddy) ─────────────────────
	handle /api/* {
		reverse_proxy backend:8080
	}
	handle /oauth/* {
		reverse_proxy backend:8080
	}
	handle /rest/* {
		reverse_proxy backend:8080
	}
	handle /rpc/* {
		reverse_proxy backend:8080
	}
	handle /.well-known/* {
		reverse_proxy backend:8080
	}
	handle /federation/* {
		reverse_proxy backend:8080
	}
	# /ws, /ws?token=..., /ws/sub — WebSocket connections
	handle /ws {
		reverse_proxy backend:8080
	}
	handle /storage/* {
		reverse_proxy backend:8080
	}
	handle /health {
		reverse_proxy backend:8080
	}

	# ── Main Web App (catch-all) ───────────────────────────────────────────
	handle {
		reverse_proxy web:80
	}
}

# ── Documentation (docs.* subdomain) ────────────────────────────────────────
docs.{$DOMAIN:localhost} {
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	log {
		output stdout
		format json
	}

	# Proxy API calls so docs can reach backend
	handle /api/* {
		reverse_proxy backend:8080
	}
	handle /oauth/* {
		reverse_proxy backend:8080
	}
	handle /.well-known/* {
		reverse_proxy backend:8080
	}

	# ── Docs SPA ───────────────────────────────────────────────────────────
	handle {
		reverse_proxy docs:80
	}
}

# ── Dev Dashboard (dev.* subdomain) ─────────────────────────────────────────
dev.{$DOMAIN:localhost} {
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	log {
		output stdout
		format json
	}

	# Proxy API calls so Dev Dashboard can reach backend
	handle /api/* {
		reverse_proxy backend:8080
	}
	handle /oauth/* {
		reverse_proxy backend:8080
	}

	# ── Dev Dashboard SPA ──────────────────────────────────────────────────
	handle {
		reverse_proxy dev-dashboard:80
	}
}
