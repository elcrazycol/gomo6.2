# =============================================================================
# Gomo6 — Caddy Reverse Proxy Configuration
# =============================================================================
# Set DOMAIN env var (e.g., example.com) for production with auto HTTPS.
# Without DOMAIN, defaults to localhost (HTTP only).
# =============================================================================

# ── Disable auto HTTPS for local development (no -k flag needed for curl) ─
#     Remove this block for production deployment with a real domain.
{
	auto_https off
}

http://{$DOMAIN:localhost} {
	# ── Security headers (applied to ALL responses) ────────────────────────
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	# ── Logging ────────────────────────────────────────────────────────────
	log {
		output stdout
		format json
	}

	# ── Backend API (WebSocket auto-upgraded by Caddy) ─────────────────────
	handle /api/* {
		reverse_proxy backend:8080
	}
	handle /oauth/* {
		reverse_proxy backend:8080
	}
	handle /rest/* {
		reverse_proxy backend:8080
	}
	handle /rpc/* {
		reverse_proxy backend:8080
	}
	handle /.well-known/* {
		reverse_proxy backend:8080
	}
	handle /federation/* {
		reverse_proxy backend:8080
	}
	# /ws, /ws?token=..., /ws/sub — WebSocket connections
	handle /ws {
		reverse_proxy backend:8080
	}
	handle /storage/* {
		reverse_proxy backend:8080
	}
	handle /health {
		reverse_proxy backend:8080
	}

	# ── Docs (sub-path /docs, prefix stripped before proxy) ────────────────
	handle_path /docs/* {
		reverse_proxy docs:80
	}

	# ── Dev Dashboard (sub-path /dev, prefix stripped before proxy) ────────
	handle_path /dev/* {
		reverse_proxy dev-dashboard:80
	}

	# ── Garage S3 Storage (replaces nginx garage-proxy) ──────────────────
	handle_path /s3/* {
		# Add CORS headers to ALL responses (including OPTIONS preflight)
		header {
			Access-Control-Allow-Origin *
			Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS, HEAD"
			Access-Control-Allow-Headers "Origin, Content-Type, Access-Control-Request-Method, Access-Control-Request-Headers"
			Access-Control-Max-Age "3600"
			Vary "Origin"
		}

		# Handle OPTIONS preflight before proxying
		@options {
			method OPTIONS
		}
		respond @options 204

		# Proxy to Garage S3, stripping its own CORS headers (avoids duplicates)
		reverse_proxy garage:3900 {
			header_down -Access-Control-Allow-Origin
			header_down -Access-Control-Allow-Methods
			header_down -Access-Control-Allow-Headers
			header_down -Access-Control-Expose-Headers
			header_down -Access-Control-Max-Age
			header_down -Access-Control-Allow-Credentials
			# Disable buffering for large file uploads/downloads
			flush_interval -1
		}
	}

	# ── Main Web App (catch-all, must be last) ─────────────────────────────
	handle {
		reverse_proxy web:80
	}
}
