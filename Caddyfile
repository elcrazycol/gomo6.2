# =============================================================================
# Gomo6 — Caddy Reverse Proxy Configuration
# =============================================================================
# Set DOMAIN env var (e.g., example.com) for production with auto HTTPS.
# Without DOMAIN, defaults to localhost (HTTP only).
#
# Subdomains (automatically derived from $DOMAIN):
#   docs.{$DOMAIN}  → Documentation site
#   dev.{$DOMAIN}   → Dev Dashboard (OAuth app management)
#
# Local development with `.localhost` TLD works out of the box:
#   localhost       → Main site
#   docs.localhost  → Documentation
#   dev.localhost   → Dev Dashboard
# =============================================================================

{
	# auto_https ON by default (no 'off' = Caddy automatically provisions TLS certs)
	# Local dev (.localhost TLD): Caddy gracefully falls back to HTTP
	# Production (real domain): Caddy gets Let's Encrypt certs automatically
	# email admin@example.com  # раскомментируй для получения писем от Let's Encrypt
}

# Uploads and object serving go through backend (/storage/v1/upload, /storage/v1/object).
# Garage is never exposed directly to browsers — no CORS issues, no S3 signature issues.

{$DOMAIN:localhost}, docs.{$DOMAIN:localhost}, dev.{$DOMAIN:localhost} {
	# ── Security headers ──────────────────────────────────────────────────
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	# ── Logging ────────────────────────────────────────────────────────────
	log {
		output stdout
		format json
	}

	# ── Documentation (docs.* subdomain) ──────────────────────────────────
	@docs host docs.{$DOMAIN:localhost}
	handle @docs {
		handle /api/* {
			reverse_proxy backend:8080
		}
		handle /oauth/* {
			reverse_proxy backend:8080
		}
		handle /.well-known/* {
			reverse_proxy backend:8080
		}
		handle {
			reverse_proxy docs:80
		}
	}

	# ── Dev Dashboard (dev.* subdomain) ───────────────────────────────────
	@dev host dev.{$DOMAIN:localhost}
	handle @dev {
		handle /api/* {
			reverse_proxy backend:8080
		}
		handle /oauth/* {
			reverse_proxy backend:8080
		}
		handle {
			reverse_proxy dev-dashboard:80
		}
	}

	# ── Main Web App (localhost or custom domain) ─────────────────────────
	@main host {$DOMAIN:localhost}
	handle @main {
		handle /api/* {
			reverse_proxy backend:8080
		}
		# /oauth/consent is a frontend SPA route, not a backend API
		handle /oauth/consent* {
			reverse_proxy web:80
		}
		handle /oauth/* {
			reverse_proxy backend:8080
		}
		handle /rest/* {
			reverse_proxy backend:8080
		}
		handle /rpc/* {
			reverse_proxy backend:8080
		}
		handle /.well-known/* {
			reverse_proxy backend:8080
		}
		handle /federation/* {
			reverse_proxy backend:8080
		}
		handle /ws {
			reverse_proxy backend:8080
		}
		handle /storage/* {
			reverse_proxy backend:8080
		}
		handle /health {
			reverse_proxy backend:8080
		}
		handle {
			reverse_proxy web:80
		}
	}
	# ── Fallback ─────────────────────────────────────────────────────────
	handle {
		respond "Not Found" 404
	}
}


