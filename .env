# Gomo6 Environment Configuration
# WARNING: This file contains sensitive values - NEVER commit to version control

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
SERVER_PORT=8080
SERVER_DOMAIN=localhost:8080
ENVIRONMENT=development

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
POSTGRES_PASSWORD=change-me-secure-password
DATABASE_URL=postgres://gomo6:change-me-secure-password@localhost:5432/gomo6?sslmode=disable

# =============================================================================
# CACHE (Redis)
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# SECURITY & AUTHENTICATION
# =============================================================================
# TODO: Generate secure random secrets for production
# JWT secret - MUST be at least 32 characters
JWT_SECRET=change-me-jwt-secret-min-32-chars-random
FEDERATION_KEY=change-me-federation-key-32-chars-random

# =============================================================================
# WEBSOCKET CORS - Allowed origins
# =============================================================================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:3000,http://localhost:8081

# =============================================================================
# STORAGE (Garage S3)
# =============================================================================
GARAGE_S3_ENDPOINT=http://localhost:3900
GARAGE_S3_PUBLIC_ENDPOINT=http://localhost:3900
GARAGE_S3_REGION=garage
GARAGE_S3_ACCESS_KEY=GK3515373e4c851ebaad366558
GARAGE_S3_SECRET_KEY=change-me-garage-secret-key-64-chars-random
GARAGE_S3_USE_SSL=false

# =============================================================================
# SUPABASE (Main web app) - Replace with your actual values
# =============================================================================
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# MESSENGER CONFIGURATION
# =============================================================================
APP_BASE_URL=http://localhost:5173
MESSENGER_BASE_URL=http://localhost:5173
SHARED_COOKIE_DOMAIN=localhost
MESSENGER_SHARED_SESSION_SECRET=change-me-long-random-secret-32-chars

# Messenger Supabase (if using separate instance)
MESSENGER_SUPABASE_URL=your-messenger-supabase-url
MESSENGER_SUPABASE_SERVICE_ROLE_KEY=your-messenger-service-role-key
