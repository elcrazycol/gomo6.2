# Gomo6 Backend Environment Configuration
# Copy this file to .env and replace all placeholder values with real secrets

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
SERVER_PORT=8080
SERVER_DOMAIN=localhost:8080
ENVIRONMENT=development

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
DATABASE_URL=postgres://gomo6:CHANGE_ME_DB_PASSWORD@localhost:5432/gomo6?sslmode=disable

# =============================================================================
# CACHE (Redis)
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# SECURITY & AUTHENTICATION
# =============================================================================
# CRITICAL: Generate secure random secrets for production!
# See SECURITY.md for generation instructions

# JWT secret - MUST be at least 32 characters
# Generate: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32

# Federation key for inter-server communication - 32+ characters
# Generate: openssl rand -base64 32
FEDERATION_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32

# =============================================================================
# STORAGE (Garage S3)
# =============================================================================
GARAGE_S3_ENDPOINT=http://localhost:3900
GARAGE_S3_PUBLIC_ENDPOINT=http://localhost:3900
GARAGE_S3_REGION=garage

# Garage S3 Access Key - use the key from docker-compose garage-init
GARAGE_S3_ACCESS_KEY=GK3515373e4c851ebaad366558

# Garage S3 Secret Key - MUST be 64+ characters
# Generate: openssl rand -hex 32
GARAGE_S3_SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

GARAGE_S3_USE_SSL=false
