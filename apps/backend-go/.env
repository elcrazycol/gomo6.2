SERVER_PORT=8080
DATABASE_URL=postgres://gomo6:gomo6password@localhost:5432/gomo6?sslmode=disable
REDIS_URL=redis://localhost:6379
JWT_SECRET=your-secret-key-change-in-production
SERVER_DOMAIN=localhost:8080
FEDERATION_KEY=your-federation-key-change-in-production
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:8081

# Garage S3 — credentials from /garage-keys/s3.env when running in Docker
# (auto-generated by garage-init). The values below are for local dev only.
GARAGE_S3_ENDPOINT=http://localhost:3900
GARAGE_S3_PUBLIC_ENDPOINT=http://localhost:3900
GARAGE_S3_REGION=garage
GARAGE_S3_USE_SSL=false
