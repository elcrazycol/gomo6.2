#!/bin/bash
set -eo pipefail

# ═══════════════════════════════════════════════════════════════════════════════
# pre-commit hook
# Запускается перед каждым коммитом, проверяет только изменённые файлы.
#
# Backend (Go) → gofmt, go mod tidy, go vet, go build, go test (изменённые pkg)
# Frontend (TS) → eslint (изменённые файлы в web, dev-dashboard, docs)
# ═══════════════════════════════════════════════════════════════════════════════

ROOT_DIR="$(pwd)"
BACKEND_DIR="apps/backend-go"
FRONTEND_DIRS=("apps/web" "apps/dev-dashboard" "apps/docs")

# ─── Цвета ───
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

pass() { echo -e " ${GREEN}✔${NC} $1"; }
fail() { echo -e " ${RED}✘${NC} $1"; }
warn() { echo -e " ${YELLOW}⚠${NC} $1"; }
task() { echo -e "\n ${BOLD}▸ $1${NC}"; }

# ─── Собираем staged файлы ───
STAGED_RAW="$(git diff --cached --name-only --diff-filter=ACM || true)"

STAGED_GO=()
STAGED_FE=()
STAGED_BACKEND=()

if [ -n "$STAGED_RAW" ]; then
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    case "$f" in
      *.go) STAGED_GO+=("$f") ;;
      *.ts|*.tsx|*.cts|*.mts)
        for dir in "${FRONTEND_DIRS[@]}"; do
          if [[ "$f" == "$dir/"* ]]; then
            STAGED_FE+=("$f")
            break
          fi
        done
        ;;
    esac
    if [[ "$f" == "$BACKEND_DIR/"* ]]; then
      STAGED_BACKEND+=("$f")
    fi
  done <<< "$STAGED_RAW"
fi

HAS_BACKEND=$(( ${#STAGED_BACKEND[@]} > 0 ))
HAS_FRONTEND=$(( ${#STAGED_FE[@]} > 0 ))

if [ "$HAS_BACKEND" -eq 0 ] && [ "$HAS_FRONTEND" -eq 0 ]; then
  pass "No staged changes to check, skipping"
  exit 0
fi

# ═══════════════════════════════════════════════════════════════════════════════
# БЕКЕНД (Go)
# ═══════════════════════════════════════════════════════════════════════════════
if [ "$HAS_BACKEND" -eq 1 ]; then
  task "Backend (Go)"

  # ── gofmt ──
  if [ ${#STAGED_GO[@]} -gt 0 ]; then
    UNFMT="$(gofmt -l "${STAGED_GO[@]}" 2>&1 || true)"
    if [ -n "$UNFMT" ]; then
      fail "gofmt — неотформатированные файлы:"
      while IFS= read -r line; do echo "    $line"; done <<< "$UNFMT"
      warn "Исправь: gofmt -w ${STAGED_GO[*]} && git add ${STAGED_GO[*]}"
      exit 1
    fi
    pass "gofmt"
  fi

  cd "$BACKEND_DIR"

  # ── go mod tidy ──
  GO_MOD_BEFORE="$(git hash-object go.mod 2>/dev/null || true)"
  GO_SUM_BEFORE="$(git hash-object go.sum 2>/dev/null || true)"
  go mod tidy 2>/dev/null
  GO_MOD_AFTER="$(git hash-object go.mod 2>/dev/null || true)"
  GO_SUM_AFTER="$(git hash-object go.sum 2>/dev/null || true)"
  if [ "$GO_MOD_BEFORE" != "$GO_MOD_AFTER" ] || [ "$GO_SUM_BEFORE" != "$GO_SUM_AFTER" ]; then
    fail "go mod tidy — изменил go.mod/go.sum:"
    git diff -- go.mod go.sum 2>/dev/null || true
    warn "Запусти: git add go.mod go.sum && git commit"
    exit 1
  fi
  pass "go mod tidy"

  # ── go vet ──
  if ! go vet ./... 2>&1; then
    fail "go vet"
    exit 1
  fi
  pass "go vet"

  # ── go build ──
  if ! go build ./... 2>&1; then
    fail "go build"
    exit 1
  fi
  pass "go build"

  # ── go test (только изменённые пакеты) ──
  if [ ${#STAGED_GO[@]} -gt 0 ]; then
    PKGS=()
    for f in "${STAGED_GO[@]}"; do
      dir="$(dirname "$f")"
      rel="${dir#"$BACKEND_DIR/"}"
      if [ "$rel" = "$dir" ]; then
        rel="."
      fi
      skip=0
      for p in "${PKGS[@]}"; do
        [ "./$rel" = "$p" ] && skip=1 && break
      done
      [ "$skip" -eq 0 ] && PKGS+=("./$rel")
    done

    if [ ${#PKGS[@]} -gt 0 ]; then
      if ! go test "${PKGS[@]}" -count=1 2>&1; then
        fail "go test (${PKGS[*]})"
        exit 1
      fi
      pass "go test (${#PKGS[@]} пакетов)"
    fi
  fi

  cd "$ROOT_DIR"
fi

# ═══════════════════════════════════════════════════════════════════════════════
# ФРОНТЕНД (ESLint + TypeCheck) — все workspace'ы
# ═══════════════════════════════════════════════════════════════════════════════
if [ "$HAS_FRONTEND" -eq 1 ]; then
  task "Frontend (ESLint + TypeCheck)"

  # Определяем какие workspace'ы затронуты
  TOUCHED_WS=()
  for dir in "${FRONTEND_DIRS[@]}"; do
    for f in "${STAGED_FE[@]}"; do
      if [[ "$f" == "$dir/"* ]]; then
        TOUCHED_WS+=("$dir")
        break
      fi
    done
  done

  # Убираем дубликаты
  TOUCHED_WS=($(echo "${TOUCHED_WS[@]}" | tr ' ' '\n' | sort -u))

  for dir in "${TOUCHED_WS[@]}"; do
    DIR_FILES=()
    for f in "${STAGED_FE[@]}"; do
      [[ "$f" == "$dir/"* ]] && DIR_FILES+=("$f")
    done

    # ── ESLint ──
    if [ -d "$dir/node_modules" ]; then
      REL_FILES=()
      for f in "${DIR_FILES[@]}"; do
        REL_FILES+=("${f#$dir/}")
      done

      cd "$dir"
      if ! npx eslint "${REL_FILES[@]}" --max-warnings=1000 2>&1; then
        fail "eslint ($dir, ${#DIR_FILES[@]} файлов)"
        exit 1
      fi
      pass "eslint ($dir, ${#DIR_FILES[@]} файлов)"
      cd "$ROOT_DIR"
    fi

    # ── TypeScript check ──
    TSC_EXIT=0
    cd "$dir"
    if [ -x "./node_modules/.bin/tsc" ]; then
      case "$dir" in
        apps/web)
          ./node_modules/.bin/tsc --noEmit -p tsconfig.app.json 2>&1 || TSC_EXIT=$?
          ;;
        apps/dev-dashboard)
          ./node_modules/.bin/tsc --noEmit -p tsconfig.json 2>&1 || TSC_EXIT=$?
          ;;
        apps/docs)
          ./node_modules/.bin/tsc --noEmit -p tsconfig.json 2>&1 || TSC_EXIT=$?
          ;;
      esac
    else
      warn "tsc не найден в $dir, пропускаю typecheck"
    fi
    cd "$ROOT_DIR"
    if [ "$TSC_EXIT" -ne 0 ]; then
      fail "tsc ($dir)"
      exit 1
    fi
    pass "tsc ($dir)"
  done
fi

# ═══════════════════════════════════════════════════════════════════════════════
pass "All pre-commit checks passed!"
